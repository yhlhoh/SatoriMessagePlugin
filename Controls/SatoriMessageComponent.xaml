<UserControl
    x:Class="SatoriMessagePlugin.Controls.SatoriMessageComponent"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="320" d:DesignHeight="80">

    <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            CornerRadius="8" Padding="12,10" Margin="4">

        <StackPanel>

            <!-- 私聊图标 -->
            <TextBlock Text="👤" FontSize="12"
                       IsVisible="{Binding Plugin.LatestMessage.IsPrivateChat}"/>
            <!-- 群聊图标 -->
            <TextBlock Text="👥" FontSize="12"
                       IsVisible="{Binding Plugin.LatestMessage.IsGroupChat}"/>

            <!-- 格式化消息 -->
            <TextBlock Text="{Binding Plugin.LatestMessage.FormattedDisplay}"
                       FontSize="13" TextTrimming="CharacterEllipsis"
                       TextWrapping="Wrap" MaxHeight="60"/>

            <!-- 时间 + 平台 -->
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                <TextBlock Text="{Binding Plugin.LatestMessage.DisplayTime}"
                           Foreground="Gray" FontSize="11"/>
                <TextBlock Text="{Binding Plugin.LatestMessage.Platform, StringFormat='· {0}'}"
                           Foreground="Gray" FontSize="11"/>
            </StackPanel>

        </StackPanel>
    </Border>
</UserControl>
