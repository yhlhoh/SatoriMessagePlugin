<ci:SettingsPageBase
    x:Class="SatoriMessagePlugin.Views.SettingsPages.SatoriSettingsPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Satori 消息设置"
    d:DesignWidth="800" d:DesignHeight="900">

    <ScrollViewer>
        <StackPanel Spacing="16" Margin="16" MaxWidth="750">

            <!-- 连接设置 -->
            <TextBlock Text="连接设置" FontSize="18" FontWeight="SemiBold"/>
            <StackPanel Spacing="6">
                <StackPanel Spacing="2">
                    <TextBlock Text="WebSocket 地址"/>
                    <TextBox Text="{Binding Settings.WebSocketUrl}" Width="400"/>
                    <TextBlock Text="Satori 协议服务器的 WebSocket 地址，例如 ws://127.0.0.1:5140/"
                               Foreground="Gray" FontSize="12"/>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="鉴权 Token"/>
                    <TextBox Text="{Binding Settings.Token}" Width="400"/>
                    <TextBlock Text="可选。Satori 服务器的 Bearer Token，留空则不发送鉴权头。"
                               Foreground="Gray" FontSize="12"/>
                </StackPanel>
            </StackPanel>

            <!-- 提醒设置 -->
            <TextBlock Text="提醒设置" FontSize="18" FontWeight="SemiBold"/>
            <StackPanel Spacing="2">
                <CheckBox IsChecked="{Binding Settings.EnableNotification}">
                    启用 ClassIsland 原生提醒
                </CheckBox>
                <TextBlock Text="收到消息时，在桌面上弹窗提醒。"
                           Foreground="Gray" FontSize="12" Margin="24,0,0,0"/>
            </StackPanel>

            <!-- 消息过滤 -->
            <TextBlock Text="消息过滤" FontSize="18" FontWeight="SemiBold"/>
            <StackPanel Spacing="6">
                <StackPanel Spacing="2">
                    <TextBlock Text="屏蔽用户 ID"/>
                    <TextBox Text="{Binding Settings.BlockedUserIds}"
                             Width="400" Height="80" AcceptsReturn="True"
                             Watermark="每行一个用户 ID"/>
                    <TextBlock Text="这些用户的私聊消息将被忽略。每行一个 ID。"
                               Foreground="Gray" FontSize="12"/>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="屏蔽频道 ID"/>
                    <TextBox Text="{Binding Settings.BlockedChannelIds}"
                             Width="400" Height="80" AcceptsReturn="True"
                             Watermark="每行一个频道 ID（群号）"/>
                    <TextBlock Text="这些频道中的消息将被忽略。每行一个 ID。"
                               Foreground="Gray" FontSize="12"/>
                </StackPanel>
            </StackPanel>

            <!-- 显示设置 -->
            <TextBlock Text="显示设置" FontSize="18" FontWeight="SemiBold"/>
            <StackPanel Spacing="6">
                <CheckBox IsChecked="{Binding Settings.ShowTimestamp}">
                    显示时间戳
                </CheckBox>
                <StackPanel Spacing="2">
                    <TextBlock Text="消息内容最大长度"/>
                    <TextBox Text="{Binding Settings.MaxContentLength}" Width="80"/>
                    <TextBlock Text="超过此长度的消息将被截断，0 表示不限制。"
                               Foreground="Gray" FontSize="12"/>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</ci:SettingsPageBase>
