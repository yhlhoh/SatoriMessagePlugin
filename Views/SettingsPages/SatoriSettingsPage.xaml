<ci:SettingsPageBase
    x:Class="SatoriMessagePlugin.Views.SettingsPages.SatoriSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SatoriMessagePlugin.Views.SettingsPages"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    mc:Ignorable="d"
    d:DesignHeight="800" d:DesignWidth="800"
    Title="Satori 消息设置"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    Background="{DynamicResource MaterialDesignPaper}"
    FontFamily="{StaticResource HarmonyOsSans}"
    TextElement.FontWeight="Regular"
    TextElement.FontSize="14"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="Auto"
    d:DataContext="{d:DesignInstance local:SatoriSettingsPage}">

    <ScrollViewer>
        <StackPanel MaxWidth="750">

            <!-- ============ 连接设置 ============ -->
            <TextBlock Text="连接设置"
                       FontSize="18" FontWeight="SemiBold"
                       Margin="0,0,0,12"/>

            <!-- WebSocket 地址 -->
            <ci:SettingsCard IconGlyph="LinkVariant"
                             Header="WebSocket 地址"
                             Description="Satori 协议服务器的 WebSocket 地址，例如 ws://127.0.0.1:5140/"
                             Margin="0 0 0 6">
                <ci:SettingsCard.Switcher>
                    <TextBox Text="{Binding Settings.WebSocketUrl, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{DynamicResource MaterialDesignBody}"
                             Width="280"/>
                </ci:SettingsCard.Switcher>
            </ci:SettingsCard>

            <!-- Token -->
            <ci:SettingsCard IconGlyph="Key"
                             Header="鉴权 Token"
                             Description="可选。Satori 服务器的 Bearer Token，留空则不发送鉴权头。"
                             Margin="0 0 0 6">
                <ci:SettingsCard.Switcher>
                    <TextBox Text="{Binding Settings.Token, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{DynamicResource MaterialDesignBody}"
                             Width="280"/>
                </ci:SettingsCard.Switcher>
            </ci:SettingsCard>

            <!-- ============ 提醒设置 ============ -->
            <TextBlock Text="提醒设置"
                       FontSize="18" FontWeight="SemiBold"
                       Margin="0,16,0,12"/>

            <!-- 启用原生提醒 -->
            <ci:SettingsCard IconGlyph="BellOutline"
                             Header="启用 ClassIsland 原生提醒"
                             Description="收到消息时，在桌面上弹窗提醒并语音播报消息内容。"
                             IsOn="{Binding Settings.EnableNotification, Mode=TwoWay}"
                             Margin="0 0 0 6"/>

            <!-- ============ 过滤设置 ============ -->
            <TextBlock Text="消息过滤"
                       FontSize="18" FontWeight="SemiBold"
                       Margin="0,16,0,12"/>

            <!-- 屏蔽用户 ID -->
            <ci:SettingsCard IconGlyph="AccountOff"
                             Header="屏蔽用户 ID"
                             Description="每行一个用户 ID。来自这些用户的私聊消息将不会被显示或提醒。"
                             Margin="0 0 0 6">
                <ci:SettingsCard.Switcher>
                    <TextBox Text="{Binding Settings.BlockedUserIds, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{DynamicResource MaterialDesignBody}"
                             Width="280"
                             Height="80"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </ci:SettingsCard.Switcher>
            </ci:SettingsCard>

            <!-- 屏蔽频道 ID -->
            <ci:SettingsCard IconGlyph="CommentRemove"
                             Header="屏蔽频道 ID"
                             Description="每行一个频道 ID（群号）。这些频道中的消息将不会被显示或提醒。"
                             Margin="0 0 0 6">
                <ci:SettingsCard.Switcher>
                    <TextBox Text="{Binding Settings.BlockedChannelIds, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{DynamicResource MaterialDesignBody}"
                             Width="280"
                             Height="80"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </ci:SettingsCard.Switcher>
            </ci:SettingsCard>

            <!-- ============ 显示设置 ============ -->
            <TextBlock Text="显示设置"
                       FontSize="18" FontWeight="SemiBold"
                       Margin="0,16,0,12"/>

            <!-- 显示时间戳 -->
            <ci:SettingsCard IconGlyph="ClockOutline"
                             Header="显示时间戳"
                             Description="在消息组件中显示接收时间。"
                             IsOn="{Binding Settings.ShowTimestamp, Mode=TwoWay}"
                             Margin="0 0 0 6"/>

            <!-- 最大内容长度 -->
            <ci:SettingsCard IconGlyph="TextShort"
                             Header="消息内容最大长度"
                             Description="超过此长度的消息内容将被截断，0 表示不限制。"
                             Margin="0 0 0 6">
                <ci:SettingsCard.Switcher>
                    <TextBox Text="{Binding Settings.MaxContentLength, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{DynamicResource MaterialDesignBody}"
                             Width="80"/>
                </ci:SettingsCard.Switcher>
            </ci:SettingsCard>

        </StackPanel>
    </ScrollViewer>
</ci:SettingsPageBase>
